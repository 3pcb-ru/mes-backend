<html lang='en'>
    <head>
        <meta charset='UTF-8' />
        <meta name='viewport' content='width=device-width, initial-scale=1.0' />
        <meta http-equiv='X-UA-Compatible' content='IE=edge' />
        <meta name='format-detection' content='telephone=no' />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
        <title>Ticket Confirmation - GRVT MES</title>
        <style>
            body, table, td, p, a, li, blockquote {
                -webkit-text-size-adjust: 100%;
                -ms-text-size-adjust: 100%;
            }
            table, td {
                mso-table-lspace: 0pt;
                mso-table-rspace: 0pt;
            }
            img {
                -ms-interpolation-mode: bicubic;
                border: 0;
                height: auto;
                line-height: 100%;
                outline: none;
                text-decoration: none;
            }
            body {
                margin: 0;
                padding: 0;
                background-color: #030213;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                color: #ffffff;
            }
            .email-container {
                width: 100%;
                background-color: #030213;
            }
            .email-body {
                max-width: 600px;
                margin: 0 auto;
                background-color: #0f172a;
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 10px;
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
                overflow: hidden;
            }
            .header-gradient {
                background: linear-gradient(to right, #06b6d4, #2563eb);
                padding: 40px 20px;
                text-align: center;
            }
            .cta-button {
                display: inline-block;
                padding: 12px 24px;
                background: linear-gradient(to right, #06b6d4, #2563eb);
                color: #ffffff !important;
                text-decoration: none;
                border-radius: 10px;
                font-weight: 600;
                font-size: 16px;
                transition: opacity 0.2s;
            }
            .success-text {
                color: #10b981;
            }
            .text-secondary {
                color: #717182;
            }
            .ticket-badge {
                display: inline-block;
                padding: 8px 16px;
                background-color: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 20px;
                font-weight: 600;
                color: #ffffff;
                margin: 16px 0;
            }
            @media screen and (max-width: 600px) {
                .email-body {
                    border-radius: 0;
                    border-left: none;
                    border-right: none;
                }
            }
        </style>
    </head>
    <body style="margin: 0; padding: 0; background-color: #030213; font-family: 'Inter', system-ui, -apple-system, sans-serif;">
        <table role='presentation' cellspacing='0' cellpadding='0' border='0' width='100%' class='email-container'>
            <tr>
                <td style='padding: 40px 20px;'>
                    <table role='presentation' cellspacing='0' cellpadding='0' border='0' width='100%' class='email-body'>
                        <!-- Header with gradient -->
                        <tr>
                            <td class="header-gradient">
                                <img src='{{baseUrl}}/public/images/logo.png' alt='GRVT MES' style='height: 48px; width: auto; display: block; margin: 0 auto;' />
                            </td>
                        </tr>

                        <!-- Main content -->
                        <tr>
                            <td style='padding: 48px 40px;'>
                                <table role='presentation' cellspacing='0' cellpadding='0' border='0' width='100%'>
                                    <tr>
                                        <td style='text-align: center; padding-bottom: 32px;'>
                                            <h1 style='margin: 0 0 16px 0; font-size: 28px; font-weight: 600; color: #10b981; line-height: 1.2;'>
                                                We've Received Your Request
                                            </h1>
                                            <p class='text-secondary' style='margin: 0; font-size: 18px; line-height: 1.5;'>
                                                Hi {{name}},
                                            </p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style='text-align: center; padding-bottom: 32px;'>
                                            <p style='margin: 0; font-size: 16px; color: #ffffff; line-height: 1.6;'>
                                                Thank you for reaching out to GRVT MES. Your support ticket has been created. Our team will review your request and get back to you shortly.
                                            </p>
                                            
                                            <div class="ticket-badge">
                                                Ticket Reference: #{{ticketNumber}}
                                            </div>

                                            <!-- CTA Button -->
                                            <table role='presentation' cellspacing='0' cellpadding='0' border='0' style='margin: 32px auto 0;'>
                                                <tr>
                                                    <td>
                                                        <a href='{{baseUrl}}/account/tickets?ticketNumber={{ticketNumber}}' class="cta-button">
                                                            Track Ticket Status
                                                        </a>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style='text-align: center; padding-top: 24px; border-top: 1px solid rgba(255, 255, 255, 0.1);'>
                                            <p style='margin: 0; font-size: 14px; color: #717182;'>
                                                <a href='{{serverBaseUrl}}/api/ticket/consent?email={{email}}&action=subscribe' style='color: #06b6d4; text-decoration: none;'>Subscribe</a>
                                                <span style='margin: 0 12px; opacity: 0.3;'>|</span>
                                                <a href='{{serverBaseUrl}}/api/ticket/consent?email={{email}}&action=unsubscribe' style='color: #717182; text-decoration: none;'>Unsubscribe</a>
                                            </p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>

                        <!-- Footer -->
                        <tr>
                            <td style='background-color: rgba(0, 0, 0, 0.2); padding: 32px 40px; border-top: 1px solid rgba(255, 255, 255, 0.1); text-align: center;'>
                                <p style='margin: 0; font-size: 12px; color: #717182;'>
                                    <strong>GRVT MES</strong><br />
                                    This is an automated confirmation.
                                </p>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>