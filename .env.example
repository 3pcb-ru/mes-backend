NODE_ENV=development

LOG_MAX_BODY_SIZE=5000
LOG_PRETTY_PRINT=true

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=your_admin_password

SERVER_PROTOCOL=https
SERVER_HOST=localhost
SERVER_PORT=4000

CLIENT_PROTOCOL=http
CLIENT_HOST=localhost:3030

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_db_user_password
POSTGRES_DB=dannie_mes

TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_USERNAME=test_user
TEST_DB_PASSWORD=test_password
TEST_DB_NAME=dannie_mes_test

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET_NAME=dannie-pcb-local
MINIO_EXPIRY=1800

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=1h
JWT_ALGORITHM=HS256
JWT_ISSUER=abbasi

SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=
SMTP_FROM=

SECURITY_HEADERS_ENABLED=true
CSP_REPORT_ONLY=true  # Must be set to false in production

RECAPTCHA_SECRET_KEY=
RECAPTCHA_ENABLED=false # Must be set to true in production

GEMINI_API_KEY=your_gemini_ai_api_key
GEMINI_MODEL=gemini-2.5-flash
